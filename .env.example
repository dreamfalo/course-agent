# ============================================================
# 智能课程助手 Agent - 环境配置文件
# 复制为 .env 后按需修改
# 生产环境请勿提交到 Git！
# ============================================================

# ─── Django ───
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-this-to-a-random-string-32chars

# ─── DeepSeek API ───
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# ─── MySQL 数据库 ───
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=course_agent_db
MYSQL_USER=root
MYSQL_ROOT_PASSWORD=course_agent_2024

# ─── Chroma 向量库 ───
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_db

# ─── MinIO 对象存储 ───
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=course-files
MINIO_SECURE=False
MINIO_CONSOLE_PORT=9001

# ─── 服务端口 ───
BACKEND_PORT=8000
FRONTEND_PORT=80

# ─── OpenAI Embedding（Chroma 向量化用） ───
OPENAI_API_KEY=sk-your-openai-api-key-here
